{
  "id": "redis",
  "version": "0.1.0",
  "displayName": "Redis Cache",
  "description": "Scaffolds a Redis cache layer and injects a Redis service into local Docker Compose files.",
  "author": "olav-official",
  "category": "infrastructure",
  "delivery": "package",
  "compatibility": { "olavMinVersion": "0.1.0" },
  "nugetPackage": { "id": "StackExchange.Redis", "version": "2.8.16" },
  "persistenceProjectSuffix": "Caching.Redis",
  "programDiCall": "builder.Services.AddRedis(builder.Configuration);",
  "generates": [
    {
      "template": "redis-di.cs.sbn",
      "output": "src/{{namespace}}.Infrastructure/Caching/Redis/DependencyInjection.cs"
    }
  ],
  "injectCompose": [
    {
      "serviceTemplate": "redis-service.yml.sbn",
      "serviceName": "redis",
      "dependsOnCondition": "service_healthy"
    }
  ],
  "parameters": [
    { "name": "connectionStringName", "type": "string", "default": "DefaultConnection" }
  ],
  "conflicts": [],
  "requires": []
}
